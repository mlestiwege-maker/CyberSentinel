APP_NAME=CyberSentinel Backend
APP_ENV=development
ALERT_ANOMALY_THRESHOLD=0.78
ALERT_CRITICAL_THRESHOLD=0.90
SIMULATION_ENABLED=true
NOTIFY_EMAIL=security-admin@example.com
NOTIFY_PHONE=
NOTIFY_PUSH_TOPIC=cybersentinel-alerts
NOTIFY_SYSTEM_ENABLED=true
NOTIFY_CHANNEL_COOLDOWN_SECONDS=20
NOTIFY_DEDUPE_WINDOW_SECONDS=120

# SMTP Configuration for Email Alerts
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Twilio Configuration for SMS Alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firebase Configuration for Push Notifications (FCM)
FIREBASE_CREDENTIALS_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=cybersentinel-3dd13
